# Starchitects Academy Flutter App - Environment Variables

# Laravel API base URL
# For local development, use your machine's LAN IP (not 127.0.0.1)
# since the emulator/device cannot reach localhost on the host machine.
API_BASE_URL=http://192.168.1.100:8001/api

# LiveKit Cloud WebSocket URL (public, not a secret)
LIVEKIT_URL=wss://st-ptyeyddn.livekit.cloud

# ⚠️ DO NOT put the following in the Flutter app:
# - Chargily secret key (server-side only)
# - LiveKit API key/secret (server-side only)
# - Google client secret (server-side only)
# - R2 keys (server-side only)
# - SMTP credentials (server-side only)
#
# Google OAuth client IDs for Android/iOS are configured in
# their respective platform files (google-services.json / Info.plist),
# NOT in this .env file.
